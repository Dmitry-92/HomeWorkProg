<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ProcContrApp1.MainWindow"
        Title="Process Controller" 
        Width="450" 
        Height="300">
    <StackPanel VerticalAlignment="Center" 
                HorizontalAlignment="Center"
                Spacing="10">
        <TextBlock Text="Управление процессом TargContpp" 
                   FontSize="16" 
                   FontWeight="Bold"/>
        
        <Button Name="StartButton" 
                Content="Запустить TargetApp" 
                Width="200" 
                Height="35"
                Background="LightGreen"
                Click="StartButtonOnClick"/>
        
        <Button Name="KillButton" 
                Content="Убить процесс TargetApp" 
                Width="200" 
                Height="35"
                Background="LightCoral"
                Click="KillButtonOnClick"
                IsEnabled="False"/>
        
        <TextBlock Name="StatusText" 
                   Text="Статус: Ожидание" 
                   FontSize="12"/>
    </StackPanel>
</Window>